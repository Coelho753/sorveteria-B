PORT=3000
MONGO_URI=mongodb://localhost:27017/sorveteria
# O backend aceita aliases comuns no Render: JWT_ACCESS_SECRET, JWT_SECRET,
# ACCESS_TOKEN_SECRET, JWT_SECRET_KEY ou SECRET_KEY para o access token.
JWT_ACCESS_SECRET=access_secret_super_forte
# O backend aceita JWT_REFRESH_SECRET, REFRESH_TOKEN_SECRET ou JWT_REFRESH_TOKEN_SECRET.
JWT_REFRESH_SECRET=refresh_secret_super_forte
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
GOOGLE_CALLBACK_URL=https://sorveteria-b.onrender.com/auth/google/callback
# Opcional: usado por npm run seed:admin
ADMIN_EMAIL=ayla@admin.com
ADMIN_PASSWORD=troque_por_uma_senha_forte
# Opcional: protege POST /orders/whatsapp
WHATSAPP_WEBHOOK_SECRET=troque_por_um_segredo_do_webhook
WHATSAPP_PHONE=5511965474023
STORE_ADDRESS=Rua exemplo, 123
STORE_HOURS=Seg a Dom, 10h às 22h
